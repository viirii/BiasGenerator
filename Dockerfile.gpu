FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-runtime

WORKDIR /app
COPY requirements/remote.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt
# LLM backends for tournament agents (Qwen, SmolLM2)
RUN pip install --no-cache-dir "transformers>=4.40" "accelerate>=0.25"
COPY . /app
RUN pip install -e .
CMD ["python", "scripts/run_northflank_glass_bridge_job.py"]
